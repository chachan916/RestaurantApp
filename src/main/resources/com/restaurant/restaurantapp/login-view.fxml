<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.restaurant.restaurantapp.LoginController"
           style="-fx-background-color: #1a1a2e;">

    <ImageView fitWidth="420" fitHeight="420"
               preserveRatio="true" opacity="0.06"
               StackPane.alignment="CENTER">
        <Image url="/images/image2.png"/>
    </ImageView>

    <VBox fx:id="rootPane" alignment="CENTER"
          style="-fx-background-color: transparent;">

        <HBox alignment="CENTER" spacing="12"
              style="-fx-background-color: #0f3460; -fx-padding: 14 24;">
            <Label text="🐦 LA FAMIGLIA DI RAVEN"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #e0d5ff;"/>
            <Label text="|" style="-fx-text-fill: #7851a9; -fx-font-size: 22;"/>
            <Label text="Italian and Basotho Cuisine"
                   style="-fx-font-size: 13; -fx-font-style: italic; -fx-text-fill: #b8b8d1;"/>
        </HBox>

        <HBox alignment="CENTER"
              style="-fx-background-color: #16213e; -fx-padding: 6 24;">
            <Label text="Benvenuti!  •  Muamuioa!  •  Welcome!"
                   style="-fx-font-size: 12; -fx-text-fill: #c9a227;
                          -fx-font-style: italic; -fx-font-weight: bold;"/>
        </HBox>

        <Region prefHeight="20"/>

        <ImageView fitWidth="110" fitHeight="110" preserveRatio="true" opacity="0.95">
            <Image url="/images/image1.png"/>
        </ImageView>

        <Region prefHeight="8"/>

        <Label text="LA FAMIGLIA DI RAVEN"
               style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #c9a227;"/>

        <Region prefHeight="16"/>

        <VBox fx:id="loginCard" spacing="14" alignment="CENTER" maxWidth="400"
              style="-fx-background-color: #0f1419; -fx-border-color: #7851a9;
                     -fx-border-width: 2; -fx-border-radius: 8;
                     -fx-background-radius: 8; -fx-padding: 28;">

            <Label text="🔑  STAFF LOGIN"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #e0d5ff;"/>
            <Separator style="-fx-background-color: #7851a9;"/>

            <VBox spacing="5">
                <Label text="👤  Username:"
                       style="-fx-text-fill: #b8b8d1; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <TextField fx:id="usernameField" promptText="Enter your username"
                           style="-fx-padding: 9; -fx-font-size: 12;
                                  -fx-control-inner-background: #1a1a2e;
                                  -fx-text-fill: #e0d5ff; -fx-prompt-text-fill: #7851a9;
                                  -fx-border-color: #7851a9; -fx-border-width: 1;
                                  -fx-border-radius: 5; -fx-background-radius: 5;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="🔐  Password:"
                       style="-fx-text-fill: #b8b8d1; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"
                               style="-fx-padding: 9; -fx-font-size: 12;
                                      -fx-control-inner-background: #1a1a2e;
                                      -fx-text-fill: #e0d5ff; -fx-prompt-text-fill: #7851a9;
                                      -fx-border-color: #7851a9; -fx-border-width: 1;
                                      -fx-border-radius: 5; -fx-background-radius: 5;"/>
            </VBox>

            <Separator style="-fx-background-color: #0f3460;"/>

            <HBox spacing="12" alignment="CENTER">
                <Button fx:id="loginBtn" text="🔓  Login"
                        style="-fx-background-color: #7851a9; -fx-text-fill: #e0d5ff;
                               -fx-font-size: 13; -fx-font-weight: bold;
                               -fx-padding: 10 26; -fx-cursor: hand; -fx-background-radius: 5;"/>
                <Button fx:id="signupBtn" text="📝  Sign Up"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: #e8f5e9;
                               -fx-font-size: 13; -fx-font-weight: bold;
                               -fx-padding: 10 26; -fx-cursor: hand; -fx-background-radius: 5;"/>
                <Button fx:id="exitBtn" text="❌  Exit"
                        style="-fx-background-color: #c62828; -fx-text-fill: #ffebee;
                               -fx-font-size: 13; -fx-font-weight: bold;
                               -fx-padding: 10 26; -fx-cursor: hand; -fx-background-radius: 5;"/>
            </HBox>
        </VBox>

        <Region prefHeight="20"/>

        <HBox alignment="CENTER"
              style="-fx-background-color: #0f3460; -fx-padding: 10 24;">
            <Label text="🌟  WELCOME — ENJOY YOUR MEAL — KEA LEBOHA!"
                   style="-fx-font-size: 11; -fx-font-style: italic; -fx-text-fill: #c9a227;"/>
        </HBox>

    </VBox>
</StackPane>